<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= status %> — Secure App</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #f0f2f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .card { background: white; border-radius: 12px; padding: 3rem; text-align: center; max-width: 400px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    h1 { font-size: 4rem; color: #4f46e5; margin-bottom: 0.5rem; }
    p { color: #666; margin-bottom: 1.5rem; }
    a { color: #4f46e5; font-weight: 600; }
  </style>
</head>
<body>
  <div class="card">
    <h1><%= status %></h1>
    <p><%= message %></p>
    <a href="/">← Go home</a>
  </div>
</body>
</html>
