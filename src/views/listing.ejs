<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Listing — RentSecure</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f0f2f5;
      color: #1a1a2e;
      min-height: 100vh;
    }
    nav {
      background: #1a1a2e;
      color: white;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand { font-weight: 700; font-size: 1.1rem; }
    .nav-links { display: flex; align-items: center; gap: 1rem; }
    .nav-link { color: #a0aec0; text-decoration: none; font-size: 0.85rem; font-weight: 600; }
    .nav-link:hover { color: white; }
    .logout-btn {
      background: #ef4444;
      color: white;
      border: none;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 600;
    }
    .logout-btn:hover { background: #dc2626; }
    .container {
      max-width: 680px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .card h2 { font-size: 1.2rem; margin-bottom: 1.5rem; color: #1a1a2e; }
    .form-group { margin-bottom: 1.2rem; }
    label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.4rem; color: #444; }
    input[type="text"], input[type="number"], input[type="file"], textarea {
      width: 100%;
      padding: 0.65rem 0.9rem;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      font-size: 0.95rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, textarea:focus { border-color: #4f46e5; }
    textarea { resize: vertical; min-height: 100px; }
    .price-wrap { position: relative; }
    .price-wrap span {
      position: absolute;
      left: 0.9rem;
      top: 50%;
      transform: translateY(-50%);
      color: #6b7280;
      font-weight: 600;
    }
    .price-wrap input { padding-left: 1.8rem; }
    .btn {
      padding: 0.65rem 1.5rem;
      background: #4f46e5;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn:hover { background: #4338ca; }
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin-bottom: 1.2rem;
      font-size: 0.9rem;
    }
    .alert-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .alert-success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .file-info { font-size: 0.78rem; color: #6b7280; margin-top: 0.4rem; }
    .file-error { color: #dc2626; font-size: 0.78rem; margin-top: 0.4rem; display: none; }
    .preview-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.5rem;
      margin-top: 0.75rem;
    }
    .preview-img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 6px;
      border: 1.5px solid #e5e7eb;
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-brand">🏠 RentSecure</div>
    <div class="nav-links">
      <a href="/home" class="nav-link">← Back to Listings</a>
      <form method="POST" action="/logout" style="margin:0;">
        <button type="submit" class="logout-btn">Sign Out</button>
      </form>
    </div>
  </nav>

  <div class="container">
    <div class="card">
      <h2>🏘 Add New Listing</h2>

      <% if (error) { %>
        <div class="alert alert-error" role="alert"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success" role="alert"><%= success %></div>
      <% } %>

      <form method="POST" action="/listings/new" enctype="multipart/form-data" novalidate>

        <div class="form-group">
          <label for="title">Property Title</label>
          <input type="text" id="title" name="title" required maxlength="128"
            placeholder="e.g. Cozy 2BR Apartment in Downtown" />
        </div>

        <div class="form-group">
          <label for="address">Address</label>
          <input type="text" id="address" name="address" required maxlength="255"
            placeholder="e.g. 123 Main St, Fredericton, NB" />
        </div>

        <div class="form-group">
          <label for="price">Monthly Rent</label>
          <div class="price-wrap">
            <span>$</span>
            <input type="number" id="price" name="price" required min="0" step="0.01"
              placeholder="1200" />
          </div>
        </div>

        <div class="form-group">
          <label for="description">Description (optional)</label>
          <textarea id="description" name="description" maxlength="2000"
            placeholder="Describe the property..."></textarea>
        </div>

        <div class="form-group">
          <label for="images">Photos (up to 5 images)</label>
          <input
            type="file"
            id="images"
            name="images"
            accept=".jpg,.jpeg,.png,.gif,.webp"
            multiple
            data-max-mb="<%= process.env.MAX_FILE_SIZE_MB || 5 %>"
          />
          <p class="file-info">
            Allowed: JPEG, PNG, GIF, WEBP · Max <%= process.env.MAX_FILE_SIZE_MB || 5 %>MB each · Max 5 images
          </p>
          <p class="file-error" id="fileError"></p>
          <div class="preview-grid" id="previewGrid"></div>
        </div>

        <button type="submit" class="btn">Submit Listing</button>
      </form>
    </div>
  </div>

  <script src="/main.js"></script>
</body>
</html>