<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moderator Panel — RentSecure</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f0f2f5;
      color: #1a1a2e;
      min-height: 100vh;
    }
    nav {
      background: #1a1a2e;
      color: white;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand { font-weight: 700; font-size: 1.1rem; }
    .nav-links { display: flex; align-items: center; gap: 1rem; }
    .nav-link { color: #a0aec0; text-decoration: none; font-size: 0.85rem; font-weight: 600; }
    .nav-link:hover { color: white; }
    .logout-btn {
      background: #ef4444;
      color: white;
      border: none;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 600;
    }
    .logout-btn:hover { background: #dc2626; }
    .container {
      max-width: 960px;
      margin: 2rem auto;
      padding: 0 1rem;
      display: grid;
      gap: 1.5rem;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .card h2 { font-size: 1.2rem; margin-bottom: 1.2rem; color: #1a1a2e; }
    .listing-row {
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 1.2rem;
      margin-bottom: 1rem;
      display: grid;
      grid-template-columns: 120px 1fr auto;
      gap: 1rem;
      align-items: start;
    }
    .listing-row:last-child { margin-bottom: 0; }
    .listing-thumb {
      width: 120px;
      height: 90px;
      object-fit: cover;
      border-radius: 8px;
      background: #e5e7eb;
      display: block;
    }
    .listing-thumb-placeholder {
      width: 120px;
      height: 90px;
      background: #e5e7eb;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: #9ca3af;
    }
    .listing-info h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
    .listing-info .address { font-size: 0.82rem; color: #6b7280; margin-bottom: 0.25rem; }
    .listing-info .price { font-size: 0.95rem; font-weight: 700; color: #4f46e5; margin-bottom: 0.25rem; }
    .listing-info .desc {
      font-size: 0.82rem;
      color: #6b7280;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .listing-info .meta { font-size: 0.78rem; color: #9ca3af; margin-top: 0.4rem; }
    .listing-actions { display: flex; flex-direction: column; gap: 0.5rem; min-width: 90px; }
    .btn-approve {
      background: #16a34a;
      color: white;
      border: none;
      padding: 0.4rem 0.8rem;
      border-radius: 6px;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
    }
    .btn-approve:hover { background: #15803d; }
    .btn-reject {
      background: #ef4444;
      color: white;
      border: none;
      padding: 0.4rem 0.8rem;
      border-radius: 6px;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
    }
    .btn-reject:hover { background: #dc2626; }
    .empty-state { text-align: center; color: #9ca3af; padding: 2rem; font-size: 0.9rem; }
    .image-count { font-size: 0.75rem; color: #6b7280; margin-top: 0.3rem; }
  </style>
</head>
<body>

  <nav>
    <div class="nav-brand">🏠 RentSecure — Moderator</div>
    <div class="nav-links">
      <a href="/home" class="nav-link">← Back to Listings</a>
      <form method="POST" action="/logout" style="margin:0;">
        <button type="submit" class="logout-btn">Sign Out</button>
      </form>
    </div>
  </nav>

  <div class="container">
    <div class="card">
      <h2>🕐 Pending Listings</h2>

      <% if (listings.length === 0) { %>
        <div class="empty-state">No pending listings. All caught up!</div>
      <% } else { %>
        <% listings.forEach(listing => { %>
          <% const imgs = listing.imageUuids ? listing.imageUuids.split(',').filter(Boolean) : []; %>
          <div class="listing-row">

            <!-- Thumbnail -->
            <% if (imgs.length > 0) { %>
              <img
                class="listing-thumb"
                src="/listings/image/<%= imgs[0] %>"
                alt="<%= listing.title %>"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="listing-thumb-placeholder" style="display:none;">🏠</div>
            <% } else { %>
              <div class="listing-thumb-placeholder">🏠</div>
            <% } %>

            <!-- Info -->
            <div class="listing-info">
              <h3><%= listing.title %></h3>
              <div class="address">📍 <%= listing.address %></div>
              <div class="price">$<%= parseFloat(listing.price).toLocaleString() %>/mo</div>
              <% if (listing.description) { %>
                <div class="desc"><%= listing.description %></div>
              <% } %>
              <div class="meta">
                By <strong><%= listing.User ? listing.User.username : 'Unknown' %></strong>
                · <%= new Date(listing.createdAt).toLocaleDateString() %>
                <% if (imgs.length > 0) { %>
                  · <%= imgs.length %> image<%= imgs.length !== 1 ? 's' : '' %>
                <% } %>
              </div>
            </div>

            <!-- Actions -->
            <div class="listing-actions">
              <form method="POST" action="/listings/<%= listing.id %>/approve">
                <button type="submit" class="btn-approve">✓ Approve</button>
              </form>
              <form method="POST" action="/listings/<%= listing.id %>/reject">
                <button type="submit" class="btn-reject">✕ Reject</button>
              </form>
            </div>

          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

</body>
</html>